* text=auto eol=lf

# Explicit text types so the checkout stays LF across platforms.
*.ts      text eol=lf
*.tsx     text eol=lf
*.js      text eol=lf
*.mjs     text eol=lf
*.cjs     text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.css     text eol=lf
*.html    text eol=lf
*.rs      text eol=lf
*.toml    text eol=lf
*.ino     text eol=lf
*.cpp     text eol=lf
*.h       text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Windows scripts keep CRLF.
*.bat     text eol=crlf
*.cmd     text eol=crlf
*.ps1     text eol=crlf

# Binary blobs: never touch.
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.icns    binary
*.pdf     binary
*.zip     binary
